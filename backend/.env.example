# ─────────────────────────────────────────────
# Copy this file to .env and fill in the values
# cp .env.example .env
# ─────────────────────────────────────────────

# SQLite database file path — no changes needed
# dev.db will be auto-created in the backend/ folder
DATABASE_URL="file:./dev.db"

# Server port
PORT=4000

# Environment
NODE_ENV=development

# JWT Secret — REQUIRED — any random string works
# Example: mysecretkey123 or any long random text
JWT_ACCESS_SECRET=supersecretjwtkey123

# AI Assistant — OPTIONAL
# If left empty, the AI chat uses smart keyword-based fallback responses
# Get a free key from: https://console.groq.com
GROQ_API_KEY=
