// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum Role {
  student
  teacher
  admin
  parent
}

enum AttendanceStatus {
  present
  absent
  late
}

enum FeeStatus {
  paid
  pending
  overdue
}

enum DoubtStatus {
  open
  answered
}

model User {
  id        String   @id @default(cuid())
  uniqueId  String?  @unique
  name      String
  email     String   @unique
  password  String
  role      Role
  createdAt DateTime @default(now())

  teacher   Teacher?
  studentEnrollments StudentEnrollment[]
  studentProfile StudentProfile?

  resume    Resume?
  studyTasks StudyTask[]
  doubts    Doubt[]

  eventRegistrations EventRegistration[]
  noticeReads NoticeRead[]
  contactMessages ContactMessage[]

  passwordResetTokens PasswordResetToken[]
  achievements        Achievement[]
  salaries            Salary[]
  activityEnrollments ActivityEnrollment[]
  parentProfile       ParentProfile?
  parentMeetingsAsTeacher ParentMeeting[] @relation("TeacherMeetings")
}

model Teacher {
  id              String   @id @default(cuid())
  userId          String   @unique
  subject         String

  // Profile fields
  phone           String?
  address         String?
  bloodType       String?
  birthday        String?
  sex             String?
  photoUrl        String?

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  courses   Course[]
}

model StudentEnrollment {
  id        String  @id @default(cuid())
  userId    String
  courseId  String
  phone     String
  createdAt DateTime @default(now())

  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  course    Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)

  submissions Submission[]
  attendance  Attendance[]
  results     Result[]
  fees         Fee[]
  doubts       Doubt[]

  @@unique([userId, courseId])
}

model StudentProfile {
  id              String  @id @default(cuid())
  userId          String  @unique
  gender          String?
  fatherName      String?
  motherName      String?
  dob             String?
  religion        String?
  fatherOccupation String?
  address         String?
  className       String?
  phone           String?
  photoUrl        String?

  user            User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Course {
  id        String   @id @default(cuid())
  name      String
  teacherId String

  teacher   Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  assignments Assignment[]
  studentEnrollments StudentEnrollment[]
  attendance Attendance[]
  results    Result[]

  attendanceQrTokens AttendanceQrToken[]
}

model Assignment {
  id          String   @id @default(cuid())
  courseId    String
  title       String
  description String
  dueDate     DateTime
  createdAt   DateTime @default(now())

  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  submissions Submission[]
  materials   AssignmentMaterial[]
}

model AssignmentMaterial {
  id           String   @id @default(cuid())
  assignmentId String
  fileUrl      String
  createdAt    DateTime @default(now())

  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
}

model Submission {
  id           String   @id @default(cuid())
  assignmentId String
  studentId    String
  fileUrl      String
  marks        Int?
  createdAt    DateTime @default(now())

  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  student      StudentEnrollment @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model AttendanceQrToken {
  id         String   @id @default(cuid())
  courseId   String
  token      String   @unique
  attendanceDate DateTime
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  course     Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

model Attendance {
  id        String   @id @default(cuid())
  studentId String
  courseId  String
  date      DateTime
  status    AttendanceStatus
  createdAt DateTime @default(now())

  student   StudentEnrollment @relation(fields: [studentId], references: [id], onDelete: Cascade)
  course    Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([studentId, courseId, date])
}

model Result {
  id        String   @id @default(cuid())
  studentId String
  courseId  String
  marks     Int
  grade     String
  createdAt DateTime @default(now())

  student   StudentEnrollment @relation(fields: [studentId], references: [id], onDelete: Cascade)
  course    Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([studentId, courseId])
}

model Fee {
  id          String    @id @default(cuid())
  studentId   String
  amount      Int       // total amount
  paidAmount  Int       @default(0)
  status      FeeStatus
  className   String?
  feeType     String    @default("tuition") // "tuition" | "exam" | "transport"
  description String?
  dueDate     String?
  createdAt   DateTime  @default(now())

  student   StudentEnrollment @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model FeeStructure {
  id        String   @id @default(cuid())
  className String
  feeType   String   @default("tuition")
  amount    Int
  dueDate   String?
  createdAt DateTime @default(now())
}

model Event {
  id          String   @id @default(cuid())
  title       String
  date        DateTime
  description String
  status      String   @default("upcoming")
  time        String?
  targetClass String   @default("All Classes")
  createdAt   DateTime @default(now())

  registrations EventRegistration[]
}

model EventRegistration {
  id        String   @id @default(cuid())
  eventId   String
  userId    String
  createdAt DateTime @default(now())

  event     Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
}

model Notice {
  id          String   @id @default(cuid())
  title       String
  description String
  date        DateTime @default(now())
  type        String   @default("notice")
  userId      String?

  reads NoticeRead[]
}

model NoticeRead {
  id        String   @id @default(cuid())
  noticeId  String
  userId    String
  readAt    DateTime @default(now())

  notice    Notice @relation(fields: [noticeId], references: [id], onDelete: Cascade)
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([noticeId, userId])
}

model Doubt {
  id        String   @id @default(cuid())
  userId    String
  studentId String?
  subject   String?
  question  String
  status    DoubtStatus @default(open)
  teacherReply String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  student   StudentEnrollment? @relation(fields: [studentId], references: [id], onDelete: SetNull)
}

model Resume {
  id        String @id @default(cuid())
  userId    String @unique
  headline  String
  summary   String
  skills    String

  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model StudyTask {
  id        String @id @default(cuid())
  userId    String
  title     String
  dueDate   DateTime
  createdAt DateTime @default(now())

  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
}

model Timetable {
  id        String   @id @default(cuid())
  type      String   @default("regular") // "regular" | "exam"
  class     String
  subject   String
  date      String?
  time      String
  teacherId String?
  createdAt DateTime @default(now())
}

model PasswordResetToken {
  id         String   @id @default(cuid())
  userId     String
  token      String   @unique
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime @default(now())

  user       User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ContactMessage {
  id          String   @id @default(cuid())
  userId      String?
  name        String
  email       String
  message     String
  teacherId   String?
  category    String   @default("general")
  senderRole  String   @default("student") // "student" | "teacher"
  status      String   @default("pending") // "pending" | "resolved"
  adminReply  String?
  createdAt   DateTime @default(now())

  user        User? @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model Holiday {
  id        String   @id @default(cuid())
  name      String
  date      String
  createdAt DateTime @default(now())
}

model Achievement {
  id          String   @id @default(cuid())
  studentId   String
  title       String
  type        String
  rank        String?
  date        String?
  createdAt   DateTime @default(now())

  student     User @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model Salary {
  id            String   @id @default(cuid())
  teacherId     String   // User.id of teacher
  month         Int      // 1–12
  year          Int
  baseSalary    Int
  hra           Int      @default(0)
  bonus         Int      @default(0)
  leaveDeduction Int     @default(0)
  latePenalty   Int      @default(0)
  netSalary     Int
  status        String   @default("pending") // "pending" | "paid"
  paidAt        DateTime?
  createdAt     DateTime @default(now())

  teacher       User @relation(fields: [teacherId], references: [id], onDelete: Cascade)
}

// ── Skill Hub ──────────────────────────────────────────────────────────────

model Activity {
  id            String   @id @default(cuid())
  name          String
  description   String
  duration      String
  fees          Int
  scheduleDays  String   // comma-separated e.g. "Mon,Wed,Fri"
  scheduleTime  String?
  targetClass   String   @default("All Classes")
  capacity      Int?
  level         String   @default("Beginner") // Beginner | Intermediate | Advanced
  batch         String   @default("Morning")  // Morning | Evening
  icon          String   @default("🎯")
  createdAt     DateTime @default(now())

  faculty       ActivityFaculty[]
  enrollments   ActivityEnrollment[]
  attendance    ActivityAttendance[]
  certificates  ActivityCertificate[]
}

model ActivityFaculty {
  id           String   @id @default(cuid())
  name         String
  activityId   String
  salaryType   String   @default("fixed") // "fixed" | "per_student"
  salaryAmount Int
  createdAt    DateTime @default(now())

  activity     Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
}

model ActivityEnrollment {
  id            String   @id @default(cuid())
  studentId     String   // User.id
  activityId    String
  paymentStatus String   @default("pending") // "pending" | "paid"
  rating        Int?     // 1–5
  createdAt     DateTime @default(now())

  student       User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  activity      Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@unique([studentId, activityId])
}

model ActivityAttendance {
  id         String   @id @default(cuid())
  studentId  String
  activityId String
  date       String
  status     String   @default("present") // "present" | "absent"
  createdAt  DateTime @default(now())

  activity   Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@unique([studentId, activityId, date])
}

model ActivityCertificate {
  id         String   @id @default(cuid())
  studentId  String
  activityId String
  issuedDate String
  createdAt  DateTime @default(now())

  activity   Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
}

// ── Parent Module ──────────────────────────────────────────────────────────

model ParentProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  phone     String?
  photoUrl  String?
  studentId String?  // User.id of the linked student

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  meetings  ParentMeeting[]
  messages  ParentMessage[]
}

model ParentMeeting {
  id        String   @id @default(cuid())
  parentId  String   // ParentProfile.id
  teacherId String   // User.id of teacher
  studentId String   // User.id of student
  date      String
  time      String
  status    String   @default("pending") // pending | accepted | rejected
  note      String?
  createdAt DateTime @default(now())

  parent    ParentProfile @relation(fields: [parentId], references: [id], onDelete: Cascade)
  teacher   User          @relation("TeacherMeetings", fields: [teacherId], references: [id], onDelete: Cascade)
}

model ParentMessage {
  id        String   @id @default(cuid())
  parentId  String   // ParentProfile.id
  teacherId String   // User.id of teacher
  senderId  String   // User.id of sender
  text      String
  createdAt DateTime @default(now())

  parent    ParentProfile @relation(fields: [parentId], references: [id], onDelete: Cascade)
}

model Performance {
  id        String   @id @default(cuid())
  studentId String   // User.id
  subject   String
  marks     Int
  examName  String
  createdAt DateTime @default(now())
}
